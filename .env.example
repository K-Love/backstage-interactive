# Database
DATABASE_URL="postgresql://user:password@your-database-host:5432/your-database-name?pgbouncer=true"
DIRECT_URL="postgresql://user:password@your-database-host:5432/your-database-name"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-using-openssl-rand-base64-32"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# OAuth Providers
GOOGLE_ID="your-google-client-id"
GOOGLE_SECRET="your-google-client-secret"
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# Add any additional environment variables with placeholder values here